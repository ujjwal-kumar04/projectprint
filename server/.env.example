# MongoDB Atlas connection string
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/photopass?retryWrites=true&w=majority

# JWT Secret — change this to a long random string in production
JWT_SECRET=replace_with_a_very_long_random_secret_string_here

# Port for Express server
PORT=5000

# Frontend URL (for CORS)
CLIENT_URL=http://localhost:5173
