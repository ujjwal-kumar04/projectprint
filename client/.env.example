# ── EmailJS ──────────────────────────────────────────────────────
# 1. Sign up at https://www.emailjs.com (free: 200 emails / month)
# 2. Dashboard → Email Services → Add Service (connect Gmail/Outlook)
# 3. Dashboard → Email Templates → Create Template
#    Use these variables in your template:
#      {{from_name}}   {{contact}}   {{shop_name}}   {{subject}}   {{message}}
# 4. Dashboard → Account → Public Key
# 5. Fill in the values below and rename this file to .env

VITE_EMAILJS_SERVICE_ID=YOUR_SERVICE_ID
VITE_EMAILJS_TEMPLATE_ID=YOUR_TEMPLATE_ID
VITE_EMAILJS_PUBLIC_KEY=YOUR_PUBLIC_KEY
VITE_ADMIN_EMAIL=admin@photopass.com
